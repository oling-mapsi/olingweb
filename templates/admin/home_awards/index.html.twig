{% extends 'base.html.twig' %}

{% block title %}Home - Awards items{% endblock %}
{% block meta_description %}Gestion des items de la section prix et reconnaissance{% endblock %}

{% block body %}
<main id="content" role="main" class="admin">
    <div class="container content-space-2 content-space-lg-3">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
            <div>
                <h1 class="h3 mb-1">Items · Prix et reconnaissance</h1>
                <p class="text-muted mb-0">Gérez les items de la section.</p>
            </div>
            <a class="btn btn-primary" href="{{ path('admin_home_awards_items_new') }}">Nouvel item</a>
        </div>

        {% include 'admin/_nav.html.twig' %}

        {% if items is empty %}
            <div class="alert alert-info">Aucun item pour l’instant.</div>
        {% else %}
            <div class="table-responsive">
                <table class="table table-hover align-middle js-admin-table">
                    <thead>
                        <tr>
                            <th>Titre</th>
                            <th>Sous-titre</th>
                            <th>Ordre</th>
                            <th>Ouvert</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in items %}
                            <tr>
                                <td class="fw-semibold">
                                    <a href="{{ path('admin_home_awards_items_edit', {id: item.id}) }}">{{ item.title }}</a>
                                </td>
                                <td>{{ item.subtitle ?: '-' }}</td>
                                <td>{{ item.position ?: '-' }}</td>
                                <td>
                                    {% if item.isOpen %}
                                        <span class="badge bg-success">Oui</span>
                                    {% else %}
                                        <span class="text-muted">Non</span>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>
</main>
{% endblock %}
