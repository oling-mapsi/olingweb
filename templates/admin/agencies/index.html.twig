{% extends 'base.html.twig' %}

{% block title %}Backoffice - Agences{% endblock %}
{% block meta_description %}Gestion des agences Oling{% endblock %}

{% block body %}
<main id="content" role="main" class="admin">
    <div class="container content-space-2 content-space-lg-3">
        <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
            <div>
                <h1 class="h3 mb-1">Agences</h1>
                <p class="text-muted mb-0">Gérez les adresses affichées dans le footer et la page contact.</p>
            </div>
            <a class="btn btn-primary" href="{{ path('admin_agencies_new') }}">Nouvelle agence</a>
        </div>

        {% include 'admin/_nav.html.twig' %}

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        {% if agencies is empty %}
            <div class="alert alert-info">Aucune agence pour l'instant.</div>
        {% else %}
            <div class="table-responsive">
                <table class="table table-hover align-middle js-admin-table">
                    <thead>
                        <tr>
                            <th>Nom</th>
                            <th>Adresse</th>
                            <th>Ordre</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for agency in agencies %}
                            <tr>
                                <td class="fw-semibold">
                                    <a href="{{ path('admin_agencies_edit', {id: agency.id}) }}">{{ agency.name }}</a>
                                </td>
                                <td>
                                    {{ agency.streetLine1 }}
                                    {% if agency.streetLine2 %}<br>{{ agency.streetLine2 }}{% endif %}
                                    <br>{{ agency.postalCode }} {{ agency.city }}
                                    <br>{{ agency.country }}
                                </td>
                                <td>{{ agency.position ?? '-' }}</td>
                                <td class="text-end">
                                    <a class="btn btn-sm btn-outline-secondary" href="{{ path('admin_agencies_edit', {id: agency.id}) }}">Modifier</a>
                                    <form method="post" action="{{ path('admin_agencies_delete', {id: agency.id}) }}" class="d-inline" onsubmit="return confirm('Supprimer cette agence ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ agency.id) }}">
                                        <button class="btn btn-sm btn-outline-danger">Supprimer</button>
                                    </form>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>
</main>
{% endblock %}
