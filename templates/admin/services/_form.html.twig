{{ form_start(form, form_action is defined ? {'action': form_action} : {}) }}
    <div class="row g-4">
        <div class="col-12">
            <div class="mb-3">
                {{ form_label(form.designation) }}
                {{ form_widget(form.designation, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.designation) }}
            </div>

            <div class="mb-3">
                {{ form_label(form.ico) }}
                <div class="admin-icon-picker js-icon-picker">
                    <div class="admin-icon-picker__input">
                        {{ form_widget(form.ico, {'attr': {'class': 'form-control js-icon-picker-input'}}) }}
                        <button type="button" class="btn btn-outline-secondary btn-sm js-icon-picker-toggle">Choisir une icône</button>
                    </div>
                    <div class="admin-icon-picker__current">
                        <span class="text-muted">Icône actuelle :</span>
                        <span class="admin-icon-picker__preview js-icon-picker-preview"></span>
                        <span class="admin-icon-picker__label js-icon-picker-label"></span>
                    </div>
                    <div class="admin-icon-picker__panel js-icon-picker-panel">
                        <div class="admin-icon-picker__search">
                            <input type="search" class="form-control js-icon-picker-search" placeholder="Rechercher une icône...">
                            <div class="admin-icon-picker__hint js-icon-picker-hint"></div>
                        </div>
                        <div class="admin-icon-picker__grid js-icon-picker-grid"></div>
                    </div>
                </div>
                {{ form_errors(form.ico) }}
            </div>

            <div class="mb-3">
                {{ form_label(form.designationShort) }}
                {{ form_widget(form.designationShort, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.designationShort) }}
            </div>

            <div class="mb-3">
                {{ form_label(form.introductionShort) }}
                {{ form_widget(form.introductionShort, {'attr': {'class': 'form-control js-wysiwyg'}}) }}
                {{ form_errors(form.introductionShort) }}
            </div>

            <div class="mb-3">
                {{ form_label(form.descriptionShort) }}
                {{ form_widget(form.descriptionShort, {'attr': {'class': 'form-control js-wysiwyg'}}) }}
                {{ form_errors(form.descriptionShort) }}
            </div>

            <div class="mb-3">
                {{ form_label(form.description) }}
                {{ form_widget(form.description, {'attr': {'class': 'form-control js-wysiwyg'}}) }}
                {{ form_errors(form.description) }}
            </div>

            <div class="mb-3">
                {{ form_label(form.practice) }}
                {{ form_widget(form.practice, {'attr': {'class': 'form-select'}}) }}
                {{ form_errors(form.practice) }}
            </div>

            <div class="mb-3">
                {{ form_label(form.teams) }}
                {{ form_widget(form.teams, {'attr': {'class': 'form-select'}}) }}
                {{ form_errors(form.teams) }}
            </div>
        </div>
    </div>

    <div class="row g-4 mt-1">
        <div class="col-12">
            <div class="admin-media-card">
                <div class="admin-media-header">
                    <div>
                        <h5>Image principale</h5>
                        <p>Image standard affichée sur les pages services.</p>
                    </div>
                </div>
                <div class="admin-media-body">
                    <div class="admin-media-preview">
                        <img class="admin-media-preview__img" src="{{ asset(service.image1 ?: 'img/1920x1080/img3.jpg') }}" alt="Image principale">
                    </div>
                    <div class="admin-media-fields">
                        {{ form_label(form.image1File) }}
                        {{ form_widget(form.image1File, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.image1File) }}
                        <details>
                            <summary>Utiliser une URL</summary>
                            <div class="mt-2">
                                {{ form_label(form.image1) }}
                                {{ form_widget(form.image1, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.image1) }}
                            </div>
                        </details>
                    </div>
                </div>
            </div>

            <div class="admin-media-card">
                <div class="admin-media-header">
                    <div>
                        <h5>Image secondaire</h5>
                        <p>Visuel complémentaire pour les pages et sections secondaires.</p>
                    </div>
                </div>
                <div class="admin-media-body">
                    <div class="admin-media-preview">
                        <img class="admin-media-preview__img" src="{{ asset(service.image2 ?: service.image1 ?: 'img/1920x1080/img5.jpg') }}" alt="Image secondaire">
                    </div>
                    <div class="admin-media-fields">
                        {{ form_label(form.image2File) }}
                        {{ form_widget(form.image2File, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.image2File) }}
                        <details>
                            <summary>Utiliser une URL</summary>
                            <div class="mt-2">
                                {{ form_label(form.image2) }}
                                {{ form_widget(form.image2, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.image2) }}
                            </div>
                        </details>
                    </div>
                </div>
            </div>

            <div class="admin-media-card">
                <div class="admin-media-header">
                    <div>
                        <h5>Image recadrée (cards hero)</h5>
                        <p>Recadre la zone qui apparaîtra dans les cartes hero de la home.</p>
                    </div>
                    <button type="button" class="btn btn-outline-secondary btn-sm js-cropper-use-existing">Recadrer l’existante</button>
                </div>
                <div class="admin-media-body">
                    <div class="admin-media-preview">
                        <img class="admin-media-preview__img" src="{{ asset(service.imageHero ?: service.image1 ?: 'img/1920x1080/img3.jpg') }}" alt="Aperçu recadrage">
                    </div>
                    <div class="admin-media-fields">
                        {{ form_label(form.imageHeroFile) }}
                        {{ form_widget(form.imageHeroFile, {'attr': {'class': 'form-control js-cropper-input', 'data-crop-aspect': '0.8'}}) }}
                        {{ form_errors(form.imageHeroFile) }}
                        <details>
                            <summary>Utiliser une URL</summary>
                            <div class="mt-2">
                                {{ form_label(form.imageHero) }}
                                {{ form_widget(form.imageHero, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.imageHero) }}
                            </div>
                        </details>
                        <div class="admin-cropper" data-input="{{ form.imageHeroFile.vars.id }}">
                            <div class="admin-cropper__header">
                                <div class="admin-cropper__label">Zone de recadrage</div>
                            </div>
                            <div class="admin-cropper__stage">
                                <img class="admin-cropper__image" src="{{ asset(service.imageHero ?: service.image1 ?: 'img/1920x1080/img3.jpg') }}" alt="Aperçu recadrage">
                            </div>
                            <div class="admin-cropper__hint">Glisse et redimensionne la zone puis enregistre.</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2 mt-4">
        <button class="btn btn-primary">{{ button_label|default('Enregistrer') }}</button>
        <a class="btn btn-outline-secondary" href="{{ path('admin_services_index') }}">Retour</a>
    </div>
{{ form_end(form) }}
