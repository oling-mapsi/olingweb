{% extends 'base.html.twig' %}

{% block title %}Ressources SEO | RGPD, AMOA SI, qualite, cyber securite - OLING{% endblock %}
{% block meta_description %}Ressources OLING sur le conseil RGPD, AMOA SI, qualite, cyber securite et transformation pour secteur public, PME et ETI.{% endblock %}

{% block body %}
<main id="content" role="main">
  <section class="oling-section oling-section--tight">
    <div class="container">
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-4">
          <li class="breadcrumb-item"><a href="{{ path('index') }}">Accueil</a></li>
          <li class="breadcrumb-item active" aria-current="page">Ressources</li>
        </ol>
      </nav>
      <span class="oling-kicker">Ressources</span>
      <h1>Guides pratiques RGPD, AMOA SI, cyber securite et qualite</h1>
      <p class="oling-lede">Des contenus de fond pour aider les decideurs publics, PME et ETI a cadrer, prioriser et executer leurs transformations SI.</p>
    </div>
  </section>

  <section class="oling-section oling-section--tight">
    <div class="container">
      <div class="row g-4">
        {% for article in articles %}
          <div class="col-md-6 col-xl-4">
            <article class="oling-surface p-4 h-100">
              <h2 class="h4 mb-3"><a class="link" href="{{ path('seo_resource', {slug: article.slug}) }}">{{ article.h1 }}</a></h2>
              <p class="mb-3">{{ article.intro }}</p>
              <a class="btn btn-outline-primary btn-sm" href="{{ path('seo_resource', {slug: article.slug}) }}">Lire l'article</a>
            </article>
          </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="oling-section oling-section--tight">
    <div class="container">
      <div class="oling-surface p-4">
        <h2 class="h4">Expertises recherchées</h2>
        <div class="row g-2">
          <div class="col-md-6"><a class="link" href="{{ path('seo_erp_progiciel') }}">Conseil ERP et progiciel</a></div>
          <div class="col-md-6"><a class="link" href="{{ path('seo_gmao') }}">Conseil GMAO</a></div>
          <div class="col-md-6"><a class="link" href="{{ path('seo_crm') }}">Conseil CRM</a></div>
          <div class="col-md-6"><a class="link" href="{{ path('seo_mapsi_progiciel') }}">MAPSI progiciel</a></div>
          <div class="col-md-6"><a class="link" href="{{ path('seo_risques_audit') }}">Gestion des risques, audit, contrôle interne</a></div>
          <div class="col-md-6"><a class="link" href="{{ path('seo_conseil_paris') }}">Cabinet de conseil à Paris</a></div>
          <div class="col-md-6"><a class="link" href="{{ path('seo_metropoles_hexagone') }}">Présence métropoles Hexagone</a></div>
          <div class="col-md-6"><a class="link" href="{{ path('seo_hexagone_drom') }}">Paris, Hexagone, DROM DOM TOM</a></div>
        </div>
      </div>
    </div>
  </section>

  <section class="oling-section oling-section--tight">
    <div class="container">
      <div class="oling-surface p-5 text-center">
        <h2>Vous avez un projet RGPD, AMOA SI, qualite ou cyber securite ?</h2>
        <p class="oling-lede">Echangeons sur vos priorites et vos contraintes pour construire un plan d'action realiste.</p>
        <div class="d-flex justify-content-center flex-wrap gap-2">
          <a class="btn btn-primary" href="{{ path('contact') }}">Parler a un consultant</a>
          <a class="btn btn-outline-primary" href="{{ path('amoa_si') }}">Voir l'offre AMOA SI</a>
        </div>
      </div>
    </div>
  </section>
</main>
{% endblock %}
