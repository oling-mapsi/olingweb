{% extends 'base.html.twig' %}

{% block title %}Home - Projets{% endblock %}
{% block meta_description %}Paramètres de la section projets sur la home{% endblock %}

{% block body %}
<main id="content" role="main" class="admin">
  <div class="container content-space-2 content-space-lg-3">
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
      <div>
        <h1 class="h3 mb-1">Home · Projets</h1>
        <p class="text-muted mb-0">Titre, intro et KPI de la section projets.</p>
      </div>
    </div>

    {% include 'admin/_nav.html.twig' %}

    {% for label, messages in app.flashes %}
      {% for message in messages %}
        <div class="alert alert-{{ label }}">{{ message }}</div>
      {% endfor %}
    {% endfor %}

    <div class="card">
      <div class="card-body">
        {{ form_start(form) }}
          {{ form_row(form.title, {'attr': {'class': 'form-control'}}) }}
          {{ form_row(form.intro) }}
          <div class="d-flex gap-2 mt-3">
            <button class="btn btn-primary">Enregistrer</button>
          </div>
        {{ form_end(form) }}
      </div>
    </div>

    <div class="card mt-4">
      <div class="card-body">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
          <div>
            <h2 class="h5 mb-1">KPI (chiffres)</h2>
            <p class="text-muted mb-0">Les 4 chiffres affichés dans la section projets de la home.</p>
          </div>
          <a class="btn btn-outline-primary" href="{{ path('admin_home_projects_kpis_new') }}">Nouveau KPI</a>
        </div>

        {% if kpis is empty %}
          <div class="alert alert-info">Aucun KPI pour l’instant.</div>
        {% else %}
          <div class="table-responsive">
            <table class="table table-hover align-middle js-admin-table">
              <thead>
                <tr>
                  <th>Chiffre</th>
                  <th>Titre</th>
                  <th>Description</th>
                  <th>Position</th>
                  <th>Actif</th>
                </tr>
              </thead>
              <tbody>
                {% for kpi in kpis %}
                  <tr>
                    <td class="fw-semibold">
                      <a href="{{ path('admin_home_projects_kpis_edit', {id: kpi.id}) }}">{{ kpi.indicator }}</a>
                    </td>
                    <td>{{ kpi.title }}</td>
                    <td>{{ kpi.description ? kpi.description|striptags|slice(0, 80) ~ '…' : '-' }}</td>
                    <td>{{ kpi.position ?? '-' }}</td>
                    <td>{{ kpi.isActive ? 'Oui' : 'Non' }}</td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</main>
{% endblock %}
