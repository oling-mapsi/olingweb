{{ form_start(form) }}
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="mb-3">
                {{ form_label(form.name) }}
                {{ form_widget(form.name, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.name) }}
            </div>

            <div class="mb-3">
                {{ form_label(form.streetLine1) }}
                {{ form_widget(form.streetLine1, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.streetLine1) }}
            </div>

            <div class="mb-3">
                {{ form_label(form.streetLine2) }}
                {{ form_widget(form.streetLine2, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.streetLine2) }}
            </div>

            <div class="row g-3">
                <div class="col-md-4">
                    {{ form_label(form.postalCode) }}
                    {{ form_widget(form.postalCode, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.postalCode) }}
                </div>
                <div class="col-md-8">
                    {{ form_label(form.city) }}
                    {{ form_widget(form.city, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.city) }}
                </div>
            </div>

            <div class="row g-3 mt-1">
                <div class="col-md-8">
                    {{ form_label(form.country) }}
                    {{ form_widget(form.country, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.country) }}
                </div>
                <div class="col-md-4">
                    {{ form_label(form.countryCode) }}
                    {{ form_widget(form.countryCode, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.countryCode) }}
                    {% if form.countryCode.vars.help %}
                        <small class="form-text text-muted">{{ form.countryCode.vars.help }}</small>
                    {% endif %}
                </div>
            </div>

            <div class="mt-3">
                {{ form_label(form.position) }}
                {{ form_widget(form.position, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.position) }}
            </div>
        </div>
    </div>

    <div class="d-flex gap-2 mt-4">
        <button class="btn btn-primary">{{ button_label|default('Enregistrer') }}</button>
        <a class="btn btn-outline-secondary" href="{{ path('admin_agencies_index') }}">Retour</a>
    </div>
{{ form_end(form) }}
