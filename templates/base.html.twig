<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
        <meta name='robots' content='index' />
       
        <title>{% block title %}{% endblock %}</title>
        <link rel="shortcut icon" href="/favicon.ico">
        {% set meta_description %}{% block meta_description %}{% endblock %}{% endset %}
        <meta name="description" content="{{ meta_description|striptags|trim }}" />
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@300;400;500;600;700&family=Sora:wght@300;400;500;600;700&display=swap" rel="stylesheet">
	    <link rel="canonical" href="{{ app.request.schemeAndHttpHost ~ app.request.pathInfo }}" />
        <meta property="og:title" content="{{ block('title')|striptags|trim }}">
        <meta property="og:description" content="{{ meta_description|striptags|trim }}">
        <meta property="og:type" content="website">
        <meta property="og:url" content="{{ app.request.schemeAndHttpHost ~ app.request.pathInfo }}">
        <meta property="og:image" content="https://oling.fr/img/og/oling-home.jpg">
        <meta name="twitter:card" content="summary_large_image">
        <meta name="twitter:title" content="{{ block('title')|striptags|trim }}">
        <meta name="twitter:description" content="{{ meta_description|striptags|trim }}">
        <meta name="theme-color" content="#0093DC">
        {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}
            
        {% endblock %}

        {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
        {% endblock %}
        <script type="application/ld+json">
        {
          "@context": "https://schema.org",
          "@type": "ProfessionalService",
          "name": "OLING Management et Technologie",
          "url": "https://oling.fr",
          "logo": "https://oling.fr/img/logo/logoling.png",
          "description": "Cabinet de conseil AMOA SI, transformation digitale et conformité réglementaire (RGPD, ISO 27001).",
          "areaServed": ["France", "Guadeloupe", "Martinique", "Guyane"],
          "email": "contact@oling.fr",
          "address": [
            {% for agency in agencies %}
            {
              "@type": "PostalAddress",
              "streetAddress": "{{ agency.streetAddress|e('js') }}",
              "postalCode": "{{ agency.postalCode|e('js') }}",
              "addressLocality": "{{ agency.city|e('js') }}",
              "addressCountry": "{{ (agency.countryCode ?: agency.country)|e('js') }}"
            }{{ not loop.last ? ',' }}
            {% endfor %}
          ],
          "sameAs": [
            "https://www.linkedin.com/company/oling-management-&-technologie/",
            "https://twitter.com/oling971"
          ]
        }
        </script>
    </head>
    {% set currentRoute = app.request.attributes.get('_route') %}
    <body class="oling-body oling-refresh{% if app.request.pathinfo == '/' %} oling-home{% endif %}{% if currentRoute starts with 'admin_' or app.request.pathinfo starts with '/admin' %} admin{% endif %}{% block body_class %}{% endblock %}" data-ga-id="G-1EN73LS1B3">
        <!-- ========== HEADER ========== -->
        <header id="header" class="oling-header mymenumoov navbar navbar-expand-lg navbar-center navbar-absolute-top navbar-show-hide"
                data-hs-header-options='{
                    "fixMoment": 0,
                    "fixEffect": "slide"
                }'>
            <div class="container">
                <nav class="js-mega-menu navbar-nav-wrap">
                    <div class="navbar-brand-wrapper">
                    <!-- Default Logo -->
                    <a class="navbar-brand" href={{ path('index')}} aria-label="Oling">
                        <img class="" src="{{ asset('/img/logo/logoling.png') }}" alt="Logo" style="height: 59px; width: auto;">
                    </a>
                    <!-- End Default Logo -->
                    </div>

                    <!-- Toggler -->
                    <button type="button" class="navbar-toggler ms-auto d-print-none" data-bs-toggle="collapse" data-bs-target="#navbarNavMenuLeftAligned" aria-label="Toggle navigation" aria-expanded="false" aria-controls="navbarNavMenuLeftAligned">
                    <span class="navbar-toggler-default d-print-none">
                        <i class="bi-list mymenuspe"></i>
                    </span>
                    <span class="navbar-toggler-toggled d-print-none">
                        <i class="bi-x"></i>
                    </span>
                    </button>
                    <!-- End Toggler -->
                
                    <!-- Collapse -->
                    <div class="navbar-nav-wrap-col collapse navbar-collapse d-print-none" id="navbarNavMenuLeftAligned">
                        <div class="navbar-absolute-top-scroller">
                            <ul class="navbar-nav nav-pills justify-content-start">
                            <li class="hs-has-mega-menu nav-item"
                                data-hs-mega-menu-item-options='{
                                    "desktop": {
                                    "position": "left",
                                    "maxWidth": "80rem"
                                    }
                                }'>
                                <a id="needsMegaMenu"
                                    class="mymenulink mt-2 nav-link dropdown-toggle hs-mega-menu-invoker"
                                    href="javascript:;"
                                    role="button"
                                    aria-expanded="false">
                                    Vos besoins
                                </a>

                                <div class="hs-mega-menu dropdown-menu oling-mega-menu oling-mega-menu--needs" aria-labelledby="needsMegaMenu">
                                    <div class="oling-mega-head">
                                        <h3>Nos expertises</h3>
                                        <a class="oling-mega-head-link" href="{{ path('projets') }}">Nos réalisations →</a>
                                    </div>
                                    <div class="oling-mega-grid">
                                        {% for practice in practices %}
                                            {% if practice.slug != 'mapsi' %}
                                                <div class="oling-mega-col">
                                                    <a class="oling-mega-col-title" href="{{ path('practice_home', {'slug': practice.slug}) }}">
                                                        {{ practice.designationShort ?: practice.designation }}
                                                    </a>
                                                    {% if practice.introductionShort %}
                                                        <p class="oling-mega-col-intro">{{ practice.introductionShort|striptags|slice(0, 120) ~ '…' }}</p>
                                                    {% endif %}
                                                    <ul class="oling-mega-links">
                                                        {% for service in practice.services %}
                                                            <li><a href="{{ path('service', {'practice' : service.practice.slug, 'slug' : service.slug}) }}">{{ service.designation | raw }}</a></li>
                                                        {% endfor %}
                                                    </ul>
                                                </div>
                                            {% endif %}
                                        {% endfor %}
                                    </div>
                                </div>
                            </li>
                            <li class="nav-item">
                                <a class="mymenulink mt-2 nav-link" href="{{ path('projets') }}">Nos projets</a>
                            </li>
                            <li class="nav-item">
                                <a class="mymenulink mt-2 nav-link" href="{{ path('apropos') }}">Nos atouts</a>
                            </li>
                            <li class="nav-item">
                                <a class="mymenulink mt-2 nav-link" href="{{ path('contact') }}">Contactez-nous</a>
                            </li>
                            <li class="nav-item ms-lg-2">
                                <a class="nav-link mapsi-link mt-2 gap-2" href="{{ path('practice_home', {'slug': 'mapsi'}) }}" aria-label="Accéder à MAPSI">
                                    <img src="{{ asset('/img/logo/mapsi.png') }}" class="logo-light-mode" alt="Logo Mapsi">
                                    <img src="{{ asset('/img/logo/mapsi_blanc.png') }}" class="logo-dark-mode" alt="Logo mapsi blanc">
                                </a>
                            </li>
{# 
                            <!-- Landings -->
                            <li class="nav-item">
                                <a class="mymenulink nav-link mt-2{% if app.request.pathinfo == '/a-propos' %} active{% endif %}" aria-current="page"  href={{ path('apropos')}} role="button" aria-expanded="false">Découvrez OLING</a>
                            </li>
                            <!-- End Landings -->

                            <!-- contact -->
                            <li class="nav-item ms-lg-auto">
                                <a class="btn btn-light d-none d-lg-inline-block" style="transform: translateY(4px);" href={{ path('contact')}}>Contactez-nous</a>
                            </li>
                           <!-- End contact --> #}

                            </ul>
                        </div>
                    </div>
                    <!-- End Collapse -->
                </nav>
            </div>
            
        </header>


        <!-- ========== END HEADER ========== -->


        {# Vignettes latérales supprimées #}


 
        {% block body %}{% endblock %}

        <div id="cookie-banner" class="oling-cookie-banner" role="dialog" aria-live="polite" aria-label="Gestion des cookies">
            <div class="oling-cookie-banner__content">
                <div class="oling-cookie-banner__text">
                    <strong>Gestion des cookies</strong>
                    <p>Nous utilisons des cookies essentiels au fonctionnement du site. Vous pouvez accepter l’ensemble des cookies ou refuser tout sauf le minimum nécessaire.</p>
                </div>
                <div class="oling-cookie-banner__actions">
                    <button type="button" class="btn btn-outline-light js-cookie-details">Voir les cookies</button>
                    <button type="button" class="btn btn-primary js-cookie-accept">Accepter tout</button>
                    <button type="button" class="btn btn-outline-light js-cookie-refuse">Refuser tout (minimum)</button>
                </div>
            </div>
            <div class="oling-cookie-banner__details">
                <div class="oling-cookie-details">
                    <div class="oling-cookie-details__block">
                        <h4>Cookies essentiels (obligatoires)</h4>
                        <div class="oling-cookie-choice">
                            <label class="oling-cookie-choice__label">
                                <input type="checkbox" checked disabled>
                                Essentiels (toujours actifs)
                            </label>
                        </div>
                        <ul>
                            <li><strong>oling_cookie_consent</strong> — mémorise votre choix de consentement.</li>
                            <li><strong>PHPSESSID</strong> — cookie de session (connexion, formulaires).</li>
                        </ul>
                    </div>
                    <div class="oling-cookie-details__block">
                        <h4>Cookies de mesure d’audience</h4>
                        <div class="oling-cookie-choice">
                            <label class="oling-cookie-choice__label">
                                <input type="checkbox" class="js-cookie-analytics">
                                Mesure d’audience (Google Analytics)
                            </label>
                        </div>
                        <ul>
                            <li><strong>_ga</strong> — identifiant Google Analytics.</li>
                            <li><strong>_ga_*</strong> — cookie GA4 lié à la propriété.</li>
                            <li><strong>_gid</strong> — mesure d’audience (Google Analytics).</li>
                        </ul>
                        <p class="oling-cookie-details__note">Les cookies de mesure d’audience ne sont déposés qu’après consentement.</p>
                    </div>
                    <div class="oling-cookie-details__actions">
                        <button type="button" class="btn btn-primary js-cookie-save">Enregistrer mes choix</button>
                    </div>
                </div>
            </div>
        </div>



        <!-- ========== FOOTER ========== -->
