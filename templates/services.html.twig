{% extends 'base.html.twig' %}

{% block title %}{{ service.designation | raw }} | AMOA SI & Conformité - OLING{% endblock %}
{% block meta_description %}{{ service.IntroductionShort|striptags }}{% endblock %}

{% block body %}
<main id="content" role="main">
  <div class="container content-space-2 content-space-lg-3 oling-service-hero-wrap">
    <section class="oling-service-hero" style="background-image: url({{ service.image2 ?: service.image1 }});">
      <div class="p-7 p-lg-9 oling-hero-content">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb mb-4">
            <li class="breadcrumb-item"><a href={{ path('index')}}>Accueil</a></li>
            <li class="breadcrumb-item"><a href={{path('practice_home',{'slug' : service.practice.slug} ) }}>{{ service.practice.designation }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ service.designation }}</li>
          </ol>
        </nav>
        <span class="oling-kicker text-white">{{ service.designationShort ?: 'Service' }}</span>
        <h1 class="display-5 text-white mb-4">{{ service.designation | raw }}</h1>
        <p class="oling-lede text-white-70 mb-4">{{ service.IntroductionShort | raw }}</p>
        <div class="oling-service-hero-icon">
          <i class="{{ service.ico ?: 'bi-diagram-3' }}"></i>
        </div>
        <div class="d-flex flex-wrap gap-3">
          <a class="btn btn-primary" href={{ path('contact')}}>Parler de votre projet</a>
          <a class="btn btn-outline-light" href={{path('practice_home',{'slug' : service.practice.slug} ) }}>Voir la practice</a>
        </div>
      </div>
    </section>
  </div>

  <section class="oling-section oling-section--tight">
    <div class="container">
      <div class="row justify-content-lg-between g-5" style="page-break-before: always;">
        <div class="col-lg-8 order-lg-2">
          <span class="oling-kicker">Contexte & besoins</span>
          <h2>Ce que couvre ce service</h2>

          {{ service.description | raw }}

          {% if service.image1 is not null and service.image1 is not empty %}
            <img class="img-fluid mt-4" src="{{ service.image1 }}" alt="{{ service.designation }}">
          {% endif %}

          <div class="oling-surface p-4 mt-4">
            <h3 class="mb-3">Livrables & résultats attendus</h3>
            <ul class="list-unstyled mb-0">
              <li class="mb-2">Diagnostic structuré et cartographie des enjeux SI.</li>
              <li class="mb-2">Plan d’actions priorisé avec indicateurs de réussite.</li>
              <li>Gouvernance, conformité et transfert de compétences.</li>
            </ul>
          </div>

          <div id="stickyBlockEndPointEg3"></div>
        </div>

        <div class="col-lg-3 d-none d-lg-block d-print-none">
          <div id="stickyBlockStartPointEg3">
            <div class="js-sticky-block"
              data-hs-sticky-block-options='{
                "parentSelector": "#stickyBlockStartPointEg3",
                "targetSelector": "#header",
                "breakpoint": "lg",
                "startPoint": "#stickyBlockStartPointEg3",
                "endPoint": "#stickyBlockEndPointEg3",
                "stickyOffsetTop": 130
              }'>
              <div class="oling-surface p-4">
                <h5 class="mb-3">Services {{ service.practice.designation }}</h5>
                <ul class="list-pointer list-pointer-secondary mb-0">
                  {% for serv in services %}
                    {% if serv.practice == service.practice %}
                      <li class="list-pointer-item">
                        <a class="link link-secondary" href={{path('service',{'practice' : serv.practice.slug, 'slug' : serv.slug} ) }}>{% if serv.id == service.id %}<strong> {% endif %} {{ serv.designation | raw }}{% if serv.id == service.id %}</strong> {% endif %}</a>
                      </li>
                    {% endif %}
                  {% endfor %}
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {% include 'includes/projects-carousel.html.twig' with { projects: service.projets } %}

  {% if service.teams|length > 0 %}
  <section class="oling-section">
    <div class="container d-print-none">
      <div class="w-lg-65 text-center mx-lg-auto mb-3 mb-sm-7 mb-lg-10">
        <h2>Nos experts</h2>
      </div>

      <div class="oling-team-mini-list oling-team-mini-list--center">
        {% for team in service.teams %}
          <div class="oling-team-mini">
            <img class="oling-team-mini__avatar" src="{{ team.photo ?: asset('img/400x400/img1.jpg') }}" alt="Photo de {{ team.noncomplet }}">
            <div class="oling-team-mini__meta">
              <div class="oling-team-mini__name">{{ team.noncomplet }}</div>
              {% if team.titre %}
                <div class="oling-team-mini__title">{{ team.titre }}</div>
              {% endif %}
              {% if team.linkedin %}
                <a class="oling-team-mini__link" href="{{ team.linkedin }}" target="_blank" rel="noopener">
                  <i class="bi-linkedin"></i> LinkedIn
                </a>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </section>
  {% endif %}
</main>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "{{ service.designation|striptags|e('js') }}",
  "serviceType": "{{ service.practice.designation|striptags|e('js') }}",
  "provider": {
    "@type": "ProfessionalService",
    "name": "OLING Management et Technologie",
    "url": "https://oling.fr"
  },
  "areaServed": ["France", "Guadeloupe", "Martinique", "Guyane"],
  "url": "{{ app.request.schemeAndHttpHost ~ app.request.pathInfo }}",
  "description": "{{ service.IntroductionShort|striptags|e('js') }}"
}
</script>
{% endblock %}
