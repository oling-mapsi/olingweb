{% extends 'base.html.twig' %}

{% block title %}Modifier item - Prix et reconnaissance{% endblock %}
{% block meta_description %}Modification d'un item de la section prix et reconnaissance{% endblock %}

{% block body %}
<main id="content" role="main" class="admin">
    <div class="container content-space-2 content-space-lg-3">
        <div class="mb-4">
            <h1 class="h3 mb-1">Modifier l’item</h1>
            <p class="text-muted mb-0">{{ item.title }}</p>
        </div>

        {% include 'admin/_nav.html.twig' %}

        {{ form_start(form) }}
            {% include 'admin/home_awards/_form.html.twig' with { form: form } %}
            <div class="d-flex gap-2 mt-4">
                <button class="btn btn-primary">Enregistrer</button>
                <a class="btn btn-outline-secondary" href="{{ path('admin_home_awards') }}">Retour</a>
            </div>
        {{ form_end(form) }}

        <form method="post" action="{{ path('admin_home_awards_items_delete', {id: item.id}) }}" onsubmit="return confirm('Supprimer cet item ?');" class="mt-4">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ item.id) }}">
            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="confirm-delete-award-{{ item.id }}" required>
                <label class="form-check-label" for="confirm-delete-award-{{ item.id }}">
                    Confirmer la suppression
                </label>
            </div>
            <button class="btn btn-outline-danger">Supprimer</button>
        </form>
    </div>
</main>
{% endblock %}
