{% extends 'base.html.twig' %}

{% block title %}Backoffice - Practices{% endblock %}
{% block meta_description %}Gestion des practices Oling{% endblock %}

{% block body %}
<main id="content" role="main" class="admin">
    <div class="container content-space-2 content-space-lg-3">
        <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
            <div>
                <h1 class="h3 mb-1">Practices</h1>
                <p class="text-muted mb-0">Gérez les pôles et leurs médias.</p>
            </div>
            <a class="btn btn-primary" href="{{ path('admin_practices_new') }}">Nouvelle practice</a>
        </div>

        {% include 'admin/_nav.html.twig' %}

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        {% if practiceItems is empty %}
            <div class="alert alert-info">Aucune practice pour l'instant.</div>
        {% else %}
            <div class="card mb-4">
                <div class="card-body">
                    <h2 class="h5 mb-2">Ordre des practices sur la home</h2>
                    <p class="text-muted mb-3">Glisse‑dépose pour définir l’ordre d’affichage sous le hero.</p>
                    {% if featuredItems is empty %}
                        <div class="text-muted">Aucune practice sélectionnée pour la home.</div>
                    {% else %}
                        <ul class="home-order-list js-home-order" data-token="{{ csrf_token('home_order') }}">
                            {% for practice in featuredItems %}
                                <li class="home-order-item" data-id="{{ practice.id }}" draggable="true">
                                    <span class="home-order-handle">⋮⋮</span>
                                    <span class="home-order-title">{{ practice.designation }}</span>
                                </li>
                            {% endfor %}
                        </ul>
                    {% endif %}
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle js-admin-table">
                    <thead>
                        <tr>
                            <th>Désignation</th>
                            <th>Home</th>
                            <th>Icône</th>
                            <th>Image</th>
                            <th>Couleur</th>
                            
                        </tr>
                    </thead>
                    <tbody>
                        {% for practice in practiceItems %}
                            <tr>
                                <td class="fw-semibold">
                                    <a href="{{ path('admin_practices_edit', {id: practice.id}) }}">{{ practice.designation }}</a>
                                </td>
                                <td>
                                    {% if practice.featuredHome %}
                                        <span class="badge bg-success">Oui</span>
                                    {% else %}
                                        <span class="text-muted">Non</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if practice.ico %}
                                        {% if practice.ico starts with '/' or practice.ico starts with 'http' %}
                                            <img src="{{ asset(practice.ico) }}" alt="Icône" style="width: 36px; height: 36px; object-fit: contain;">
                                        {% else %}
                                            <i class="{{ practice.ico }}"></i>
                                        {% endif %}
                                    {% else %}
                                        <span class="text-muted">-</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if practice.image1 %}
                                        <img src="{{ asset(practice.image1) }}" alt="Image" style="width: 80px; height: 50px; object-fit: cover;">
                                    {% else %}
                                        <span class="text-muted">-</span>
                                    {% endif %}
                                </td>
                                <td>{{ practice.color ?: '-' }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>
</main>
{% endblock %}
