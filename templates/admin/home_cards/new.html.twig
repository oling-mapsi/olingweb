{% extends 'base.html.twig' %}

{% block title %}Nouveau Home highlight{% endblock %}
{% block meta_description %}Création d'un Home highlight{% endblock %}

{% block body %}
<main id="content" role="main" class="admin">
    <div class="container content-space-2 content-space-lg-3">
        <div class="mb-4">
            <h1 class="h3 mb-1">Nouveau Home highlight</h1>
            <p class="text-muted mb-0">Choisissez une entité à afficher sous le hero.</p>
        </div>

        {% include 'admin/_nav.html.twig' %}

        <div class="card">
            <div class="card-body">
                {% include 'admin/home_cards/_form.html.twig' with {
                    form: form,
                    button_label: 'Créer'
                } %}
            </div>
        </div>
    </div>
</main>
{% endblock %}
