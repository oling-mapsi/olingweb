{% extends 'base.html.twig' %}

{% block title %}OLING — Cabinet de conseil AMOA SI, ERP, CRM, GMAO (Paris, Hexagone & DROM){% endblock %}
{% block meta_description %}Cabinet de conseil AMOA SI, ERP, CRM, GMAO, risques, audit et conformité. Présence à Paris, dans l'Hexagone et en DROM (Guadeloupe, Martinique, Guyane, Réunion).{% endblock %}

{% block body %}

<!-- ========== MAIN CONTENT ========== -->
<main id="content" class="acc-home">
<div class="acc-home-bg" aria-hidden="true"></div>
<div class="acc-home-grain" aria-hidden="true"></div>
{% set practiceAmoa = null %}
{% for practice in practices %}
  {% if practice.slug == 'consulting' %}
    {% set practiceAmoa = practice %}
  {% endif %}
{% endfor %}

{% if homeHeroSection %}
<section class="acc-hero acc-hero--home">
  {% if flashInfo %}
  <a class="acc-hero-flash" href="{{ path('polsecurite') }}">
    <div class="acc-hero-flash__body">
      {% if flashInfo.imageHero or flashInfo.imagePath %}
        <img class="acc-hero-flash__image" src="{{ asset(flashInfo.imageHero ?: flashInfo.imagePath) }}" alt="{{ flashInfo.title }}">
      {% endif %}
      <div class="acc-hero-flash__text">{{ flashInfo.title }}</div>
    </div>
  </a>
  {% endif %}
  <div class="container acc-hero-shell">
    <div class="acc-hero-copy">
      {% if homeHeroSection.title %}
        <h1 class="acc-hero-title">{{ homeHeroSection.title }}</h1>
      {% endif %}
      {% if homeHeroSection.intro %}
        <p class="acc-hero-subtitle">{{ homeHeroSection.intro | raw }}</p>
      {% endif %}
      <div class="acc-hero-cta">
        {% if homeHeroSection.ctaLabel and homeHeroSection.ctaUrl %}
          <a class="btn btn-primary" href="{{ homeHeroSection.ctaUrl }}">{{ homeHeroSection.ctaLabel }}</a>
        {% endif %}
        {% if homeHeroSection.ctaLabelSecondary and homeHeroSection.ctaUrlSecondary %}
          <a class="btn btn-outline-dark" href="{{ homeHeroSection.ctaUrlSecondary }}">{{ homeHeroSection.ctaLabelSecondary }}</a>
        {% endif %}
      </div>
    </div>
    <aside class="acc-hero-motion" aria-label="Domaines pilotes par OLING">
      <span class="acc-hero-motion-kicker">Execution en continu</span>
      <div class="acc-hero-orbit" aria-hidden="true">
        <span class="acc-hero-orbit-ring acc-hero-orbit-ring--outer"></span>
        <span class="acc-hero-orbit-ring acc-hero-orbit-ring--mid"></span>
        <span class="acc-hero-orbit-ring acc-hero-orbit-ring--inner"></span>
        <span class="acc-hero-orbit-core"></span>
        <span class="acc-hero-orbit-node acc-hero-orbit-node--1">ERP</span>
        <span class="acc-hero-orbit-node acc-hero-orbit-node--2">GMAO</span>
        <span class="acc-hero-orbit-node acc-hero-orbit-node--3">CRM</span>
        <span class="acc-hero-orbit-node acc-hero-orbit-node--4">RGPD</span>
        <span class="acc-hero-orbit-node acc-hero-orbit-node--5">Cyber</span>
        <span class="acc-hero-orbit-node acc-hero-orbit-node--6">AMOA SI</span>
      </div>
      <div class="acc-hero-flow">
        <span>Paris</span>
        <span>Hexagone</span>
        <span>Guadeloupe</span>
        <span>Martinique</span>
        <span>Guyane</span>
        <span>Reunion</span>
      </div>
    </aside>
  </div>

  {% if homeCards is defined and homeCards|length > 0 %}
  <div class="container acc-hero-insights">
    {% set cards = [] %}
    {% for homeCard in homeCards %}
      {% if homeCard.service %}
        {% set service = homeCard.service %}
        {% set cards = cards|merge([{
          'tag': 'Service',
          'title': service.designation,
          'text': service.introductionShort ?: service.descriptionShort ?: (service.description ? service.description|striptags|slice(0, 140) ~ '…' : ''),
          'image': service.imageHero ?: service.image1 ?: asset('img/1920x1080/img3.jpg'),
          'url': path('service', {'practice' : service.practice.slug, 'slug' : service.slug})
        }]) %}
      {% elseif homeCard.projet %}
        {% set projet = homeCard.projet %}
        {% set projetService = projet.services|length ? projet.services|first : null %}
        {% set cards = cards|merge([{
          'tag': 'Projet',
          'title': projet.designation,
          'text': projet.description ? projet.description|striptags|slice(0, 140) ~ '…' : 'Projet stratégique piloté par OLING.',
          'image': projet.imageHero ?: projet.image ?: asset('img/1920x1080/img7.jpg'),
          'url': projetService ? path('service', {'practice' : projetService.practice.slug, 'slug' : projetService.slug}) : path('contact')
        }]) %}
      {% elseif homeCard.metier %}
        {% set metier = homeCard.metier %}
        {% set cards = cards|merge([{
          'tag': 'Métier',
          'title': metier.designation,
          'text': 'Projets ciblés et accompagnement sur-mesure pour les directions métiers.',
          'image': metier.imageHero ?: metier.image ?: asset('img/1920x1080/img12.jpg'),
          'url': path('metiers')
        }]) %}
      {% endif %}
    {% endfor %}

    <div class="acc-insights-grid">
      {% for card in cards %}
      <a class="acc-insight-card" href="{{ card.url }}" style="--card-bg: url('{{ card.image }}');" data-bg="{{ card.image }}">
        <div class="acc-insight-overlay">
          <span class="acc-tag">{{ card.tag }}</span>
          <h3><span class="acc-insight-title-text">{{ card.title | raw }}</span></h3>
        </div>
        <div class="acc-insight-body">
          <p>{{ card.text | raw }}</p>
          <span class="acc-link">Découvrir</span>
        </div>
      </a>
      {% endfor %}
    </div>
  </div>
  {% endif %}
</section>
{% endif %}

{% if homePractices is defined and homePractices|length > 0 %}
<section class="acc-practices">
  <div class="container">
    {% set practicePalette = ['#7d5ba6','#0093dc','#8aea92','#f4743b'] %}
    {% set practiceGrad2Palette = ['#3d2672','#0b4cc2','#1f7a5a','#a8461e'] %}
    {% set practiceColorMap = {'#7d5ba6':0,'#0093dc':1,'#8aea92':2,'#f4743b':3} %}
    <div class="acc-practices-head acc-practices-head--center">
      <h2 class="acc-section-title">{{ homePracticesSection and homePracticesSection.title ? homePracticesSection.title : 'Des pôles d’expertise pilotés, outillés et orientés résultats.' }}</h2>
    </div>
    <div class="acc-practice-grid accenture-grid acc-practice-process">
      {% for practice in homePractices %}
        {% set practiceColor = practice.color ? (practice.color starts with('#') ? practice.color|lower : '#' ~ practice.color|lower) : '' %}
        {% set variant = practiceColorMap[practiceColor] is defined ? practiceColorMap[practiceColor] : (practice.id ? (practice.id % 4) : (loop.index % 4)) %}
        {% set practiceAccent = practiceColor ? practiceColor : practicePalette[variant] %}
        {% set practiceGrad2 = practiceGrad2Palette[variant] %}
        <a class="acc-practice-step" data-step="{{ '%02d'|format(loop.index) }}"
           data-variant="{{ variant }}"
           href="{{ path('practice_home', {'slug': practice.slug}) }}"
           style="--practice-bg: url('{{ practice.image1 ?: asset('img/1920x1080/img9.jpg') }}'); --practice-accent: {{ practiceAccent }}; --card-grad-1: {{ practiceAccent }}; --card-grad-2: {{ practiceGrad2 }};">
          <div class="acc-practice-step-media" aria-hidden="true"></div>
          <div class="acc-practice-step-content">
            <h3>{{ practice.designationShort ?: practice.designation }}</h3>
            <p>{{ practice.introductionShort ? practice.introductionShort|striptags|slice(0, 120) ~ '…' : (practice.descriptionShort ? practice.descriptionShort|striptags|slice(0, 120) ~ '…' : (practice.description ? practice.description|striptags|slice(0, 120) ~ '…' : '')) }}</p>
            <div class="acc-practice-step-footer">
              {% if practice.tags is defined and practice.tags|length > 0 %}
              <div class="acc-practice-tags">
                {% for tag in practice.tags|slice(0, 5) %}
                  <span class="acc-practice-tag">{{ tag starts with('#') ? tag : '#' ~ tag }}</span>
                {% endfor %}
              </div>
              {% endif %}
              <span class="btn btn-icon-only" aria-hidden="true"></span>
            </div>
          </div>
        </a>
      {% endfor %}
    </div>

    {% if homePracticesSection and homePracticesSection.intro %}
    <div class="acc-practices-foot acc-practices-head--center">
      <div class="acc-practices-subtitle-wrap">
        <p class="acc-practices-subtitle">{{ homePracticesSection.intro | raw }}</p>
      </div>
    </div>
    {% endif %}
  </div>
</section>
{% endif %}

<section class="acc-value">
  <div class="container">
    <div class="acc-value-head">
      <div class="acc-value-head-copy">
        <h2 class="acc-section-title">{{ homeProjectsSection and homeProjectsSection.title ? homeProjectsSection.title : 'Chaque jour, nous nous emparons du changement et générons des résultats concrets.' }}</h2>
        <p class="acc-lede">{{ homeProjectsSection and homeProjectsSection.intro ? homeProjectsSection.intro|raw : 'Votre allié tactique et organisationnel pour mener à bien vos initiatives stratégiques.' }}</p>
      </div>
    </div>
    <div class="acc-value-kpis-row">
      <div class="acc-value-kpis acc-value-kpis--stacked">
        {% if homeProjectKpis is defined and homeProjectKpis|length > 0 %}
          {% for kpi in homeProjectKpis|slice(0, 4) %}
            <div class="acc-value-kpi">
              <span class="acc-value-kpi-indicator">{{ kpi.indicator }}</span>
              <span class="acc-value-kpi-title">{{ kpi.title }}</span>
              <span class="acc-value-kpi-desc">{{ kpi.description }}</span>
            </div>
          {% endfor %}
        {% else %}
          <div class="acc-value-kpi">
            <span class="acc-value-kpi-indicator">+200</span>
            <span class="acc-value-kpi-title">Projets pilotés</span>
            <span class="acc-value-kpi-desc">AMOA, transformation SI et conformité menés de bout en bout.</span>
          </div>
          <div class="acc-value-kpi">
            <span class="acc-value-kpi-indicator">95%</span>
            <span class="acc-value-kpi-title">Taux de succès</span>
            <span class="acc-value-kpi-desc">Projets sécurisés et cadrés par notre méthodologie ISO 27001.</span>
          </div>
          <div class="acc-value-kpi">
            <span class="acc-value-kpi-indicator">12</span>
            <span class="acc-value-kpi-title">Secteurs couverts</span>
            <span class="acc-value-kpi-desc">Public, finance, industrie, santé et services essentiels.</span>
          </div>
          <div class="acc-value-kpi">
            <span class="acc-value-kpi-indicator">+5&nbsp;000</span>
            <span class="acc-value-kpi-title">Collaborateurs couverts</span>
            <span class="acc-value-kpi-desc">Agents et salariés protégés par nos dispositifs DPO.</span>
          </div>
        {% endif %}
      </div>
    </div>

    <div class="acc-carousel swiper js-swiper-acc-value">
      <div class="swiper-wrapper">
        {% if projets|length > 0 %}
          {% for projet in projets %}
          {% set projetService = projet.services|length ? projet.services|first : null %}
          <div class="swiper-slide">
            <a class="acc-value-card acc-value-card--thumb" href="{{ projetService ? path('service', {'practice' : projetService.practice.slug, 'slug' : projetService.slug}) : path('contact') }}">
              <div class="acc-value-card-head">
                <div class="acc-value-thumb" style="background-image: url('{{ projet.image ?: asset('img/1920x1080/img5.jpg') }}');"></div>
                <div class="acc-value-meta">
                  <span class="acc-tag">{{ projet.metier ? projet.metier.designation : 'Projet' }}</span>
                  <h3>{{ projet.designation | raw }}</h3>
                </div>
              </div>
              <div class="acc-value-body">
                <p>{{ projet.description ? projet.description|striptags|slice(0, 120) ~ '…' : 'Pilotage, transformation et conformité sur des projets SI structurants.' }}</p>
                <span class="acc-link">Voir le projet</span>
              </div>
            </a>
          </div>
          {% endfor %}
        {% else %}
          {% for practice in practices %}
          {% if practice.slug != 'mapsi' %}
          <div class="swiper-slide">
            <a class="acc-value-card acc-value-card--thumb" href="{{ path('practice_home', {'slug': practice.slug}) }}">
              <div class="acc-value-card-head">
                <div class="acc-value-thumb" style="background-image: url('{{ practice.image1 ?: asset('img/1920x1080/img5.jpg') }}');"></div>
                <div class="acc-value-meta">
                  <span class="acc-tag">Practice</span>
                  <h3>{{ practice.designation }}</h3>
                </div>
              </div>
              <div class="acc-value-body">
                <p>{{ practice.introductionShort | raw }}</p>
                <span class="acc-link">En savoir plus</span>
              </div>
            </a>
          </div>
          {% endif %}
          {% endfor %}
        {% endif %}

        <div class="swiper-slide">
          <div class="acc-value-card acc-value-card--stats">
            <div class="acc-value-body">
              <span class="acc-tag">Chiffres clés</span>
              <h3>OLING en action</h3>
              <ul class="acc-stats">
                <li><strong>+100</strong> Projets SI et conformité</li>
                <li><strong>10+</strong> Consultants experts</li>
                <li><strong>2012</strong> Année de création</li>
                <li><strong>4</strong> Territoires couverts</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="acc-carousel-toolbar acc-carousel-toolbar--below">
      <div class="acc-carousel-nav">
        <button class="acc-carousel-prev js-acc-value-prev" type="button" aria-label="Précédent">‹</button>
        <button class="acc-carousel-next js-acc-value-next" type="button" aria-label="Suivant">›</button>
      </div>
      <div class="acc-carousel-meta">
        <span class="acc-carousel-count"><span class="js-acc-value-current">1</span>/<span class="js-acc-value-total">1</span></span>
        <button class="acc-carousel-toggle js-acc-value-toggle" type="button" aria-pressed="false" data-state="playing">Pause</button>
      </div>
    </div>
  </div>
</section>

<section class="acc-awards">
  <div class="container">
    <div class="acc-section-head">
      <span class="acc-eyebrow acc-eyebrow--dark">{{ homeAwardsSection and homeAwardsSection.eyebrow ? homeAwardsSection.eyebrow : 'Prix et reconnaissance internationale' }}</span>
      <h2 class="acc-section-title">{{ homeAwardsSection and homeAwardsSection.title ? homeAwardsSection.title : 'La confiance se construit sur des preuves concrètes.' }}</h2>
    </div>
    <div class="acc-awards-list">
      {% if homeAwards is defined and homeAwards|length > 0 %}
        {% for award in homeAwards %}
          <details class="acc-award" {% if award.isOpen %}open{% endif %}>
            <summary>
              <span class="acc-award-title">{{ award.title }}</span>
              <span class="acc-award-sub">{{ award.subtitle }}</span>
            </summary>
            <p>{{ award.body|raw }}</p>
          </details>
        {% endfor %}
      {% else %}
        <details class="acc-award" open>
          <summary>
            <span class="acc-award-title">Une gouvernance d'entreprise éthique</span>
            <span class="acc-award-sub">Cadre ISO 27001, pilotage responsable et traçabilité renforcée.</span>
          </summary>
          <p>OLING structure les programmes de conformité et de sécurité avec des méthodes de pilotage exigeantes, centrées sur la valeur et la conformité.</p>
        </details>
        <details class="acc-award">
          <summary>
            <span class="acc-award-title">Un cabinet de confiance</span>
            <span class="acc-award-sub">DPO certifié, audits réguliers, gouvernance RGPD.</span>
          </summary>
          <p>Nos experts accompagnent des organisations publiques et privées avec un niveau de preuve continu : documentation, audits, indicateurs et plans d’action.</p>
        </details>
        <details class="acc-award">
          <summary>
            <span class="acc-award-title">Un pilotage outillé</span>
            <span class="acc-award-sub">MAPSI industrialise les audits et la conformité.</span>
          </summary>
          <p>MAPSI centralise les plans d’action, incidents, registres et reportings pour une traçabilité complète et partagée.</p>
        </details>
      {% endif %}
    </div>
  </div>
</section>

<section class="acc-careers acc-contact">
  <div class="acc-careers-media" style="background-image: url('{{ asset('img/1920x1080/img11.jpg') }}');"></div>
  <div class="container">
    <div class="row align-items-center g-5">
      <div class="col-lg-7">
        <span class="acc-eyebrow">Contact</span>
        <h2 class="acc-section-title acc-section-title--light">Planifiez un échange de cadrage de 30 minutes</h2>
        <p class="acc-lede acc-lede--light">Parlons de vos enjeux AMOA, SI et conformité. Nous clarifions le périmètre, les priorités et le plan d’action.</p>
      </div>
      <div class="col-lg-5 text-lg-end">
        <a class="btn btn-outline-light" href="{{ path('contact') }}">Réserver un échange</a>
      </div>
    </div>
  </div>
</section>

</main>
<!-- ========== END MAIN CONTENT ========== -->

  

  <!-- ========== SECONDARY CONTENTS ========== -->
  <!-- Go To -->
  <a class="js-go-to go-to position-fixed" href="javascript:;" style="visibility: hidden;"
     data-hs-go-to-options='{
       "offsetTop": 700,
       "position": {
         "init": {
           "right": "2rem"
         },
         "show": {
           "bottom": "2rem"
         },
         "hide": {
           "bottom": "-2rem"
         }
       }
     }'>
    <i class="bi-chevron-up"></i>
  </a>

{% endblock %}
