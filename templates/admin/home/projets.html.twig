{% extends 'base.html.twig' %}

{% block title %}Home - Projets{% endblock %}
{% block meta_description %}Sélection des projets mis en avant{% endblock %}

{% block body %}
<main id="content" role="main" class="admin">
  <div class="container content-space-2 content-space-lg-3">
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
      <div>
        <h1 class="h3 mb-1">Home · Projets</h1>
        <p class="text-muted mb-0">Choisis les 6 projets mis en avant et leur ordre d’affichage.</p>
      </div>
    </div>

    {% include 'admin/_nav.html.twig' %}

    {% for label, messages in app.flashes %}
      {% for message in messages %}
        <div class="alert alert-{{ label }}">{{ message }}</div>
      {% endfor %}
    {% endfor %}

    <div class="card mb-4">
      <div class="card-body">
        <h2 class="h5 mb-2">Projets mis en avant (6 max)</h2>
        <p class="text-muted mb-3">Glisse‑dépose pour définir l’ordre d’affichage.</p>
        {% if featuredItems is empty %}
          <div class="text-muted">Aucun projet mis en avant pour l'instant.</div>
        {% else %}
          <ul class="home-order-list js-home-order" data-token="{{ csrf_token('projets_featured_order') }}" data-endpoint="{{ path('admin_projets_featured_order') }}">
            {% for projet in featuredItems %}
              <li class="home-order-item" data-id="{{ projet.id }}" draggable="true">
                <span class="home-order-handle">⋮⋮</span>
                <span class="home-order-title">{{ projet.designation }}</span>
              </li>
            {% endfor %}
          </ul>
        {% endif %}
      </div>
    </div>

    <div class="card">
      <div class="card-body">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
          <div>
            <h2 class="h5 mb-1">Sélection</h2>
            <p class="text-muted mb-0">Coche jusqu’à 6 projets.</p>
          </div>
          <small class="text-muted js-featured-counter">0/6 sélectionnés</small>
        </div>

        <form method="post" class="js-featured-projects-form" data-max="6">
          <input type="hidden" name="_token" value="{{ csrf_token('home_projets') }}">
          <div class="table-responsive">
            <table class="table table-hover align-middle js-admin-table">
              <thead>
                <tr>
                  <th>Mettre en avant</th>
                  <th>Désignation</th>
                  <th>Métier</th>
                  <th>Image</th>
                </tr>
              </thead>
              <tbody>
                {% for projet in projets %}
                  <tr>
                    <td>
                      <input class="form-check-input js-featured-projects-check" type="checkbox" name="featured_ids[]" value="{{ projet.id }}" {% if projet.featuredProjects %}checked{% endif %}>
                    </td>
                    <td class="fw-semibold">
                      <a href="{{ path('admin_projets_edit', {id: projet.id}) }}">{{ projet.designation }}</a>
                    </td>
                    <td>{{ projet.metier ? projet.metier.designation : '-' }}</td>
                    <td>
                      {% if projet.image %}
                        <img src="{{ asset(projet.image) }}" alt="Image" style="width: 80px; height: 50px; object-fit: cover;">
                      {% else %}
                        <span class="text-muted">-</span>
                      {% endif %}
                    </td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
          <div class="d-flex gap-2 mt-3">
            <button class="btn btn-primary">Enregistrer</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</main>
{% endblock %}
